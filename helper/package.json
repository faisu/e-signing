{
  "name": "bridgeit-dsc-helper",
  "version": "1.0.0",
  "description": "Open-source localhost DSC helper — talks to CCA Class 3 tokens via PKCS#11 / node-forge",
  "main": "src/server.js",
  "bin": {
    "bridgeit-helper": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build:win": "pkg . --targets node22-win-x64 --output dist/bridgeit-helper-win.exe",
    "build:mac": "pkg . --targets node22-mac-arm64,node22-mac-x64 --output dist/bridgeit-helper-mac",
    "build:linux": "pkg . --targets node22-linux-x64 --output dist/bridgeit-helper-linux",
    "build": "npm run build:win && npm run build:mac && npm run build:linux"
  },
  "pkg": {
    "assets": [
      "node_modules/graphene-pk11/build/Release/*.node"
    ],
    "scripts": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "node-forge": "^1.3.1",
    "graphene-pk11": "^2.3.6",
    "selfsigned": "^2.4.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0"
  }
}
