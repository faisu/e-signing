{
  "manifest_version": 3,
  "name": "AutoDCR Native Signing Bridge",
  "description": "Trusted bridge between the web app and native token signer host.",
  "version": "0.1.1",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://192.168.1.8:3000/*", "http://localhost:3000/*", "https://autodcr.vercel.app/*"],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
